<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="RFD Laundry - 3 Test Cases Performance Transaksi">
      <stringProp name="TestPlan.comments">
=== DAFTAR TEST CASE ===
TC01 - Load Test       : 1000 user simultan, response time maks 4 detik
TC02 - Stress Test     : Cari batas maksimum user sebelum aplikasi crash
TC03 - Database Test   : 500 user baca/tulis transaksi bersamaan, ukur eksekusi DB

=== CARA PAKAI ===
Jalankan 1 test case saja per run (enable 1 Thread Group, disable 2 lainnya)
Klik kanan Thread Group Ã¢â€ â€™ Enable/Disable
      </stringProp>
      <boolProp name="TestPlan.serialize_threadgroups">true</boolProp>
      <boolProp name="TestPlan.tearDown_on_shutdown">true</boolProp>
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments" guiclass="ArgumentsPanel" testclass="Arguments" testname="User Defined Variables">
        <collectionProp name="Arguments.arguments">
          <elementProp name="BASE_URL" elementType="Argument">
            <stringProp name="Argument.name">BASE_URL</stringProp>
