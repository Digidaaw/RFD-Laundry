          </elementProp>
        </HTTPSamplerProxy>
        <hashTree>
          <RegexExtractor guiclass="RegexExtractorGui" testclass="RegexExtractor" testname="Ekstrak ID Transaksi Baru dari Redirect URL" enabled="true">
            <stringProp name="RegexExtractor.useHeaders">true</stringProp>
            <stringProp name="RegexExtractor.refname">new_transaksi_id</stringProp>
            <stringProp name="RegexExtractor.regex">Location: .*/transaksi.*show_print_modal=(\d+)</stringProp>
