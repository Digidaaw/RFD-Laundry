<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="RFD Laundry - Transaksi VOLUME Test (TC-VOL-01 and TC-VOL-02)" enabled="true">
      <stringProp name="TestPlan.comments">
====================================================================
JENIS TEST : VOLUME TESTING - PRE-AUTH SESSION
FITUR      : MENGELOLA DATA TRANSAKSI
TESTER     : FAI

METODE     : Pre-Authenticated Session
             Login manual via browser, laravel_session dipakai JMeter.
             Tidak ada step login - langsung akses /transaksi.
             Menghindari CSRF issue pada artisan serve (single-thread).

TC-VOL-01 LOCAL : 500 user | Ramp-up 60s | Loop 3 | localhost:8000
TC-VOL-02 DEPLOY: 50 user  | Ramp-up 60s | Loop 3 | laundry.aksaralearning.com
====================================================================
      </stringProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <boolProp name="TestPlan.serialize_threadgroups">false</boolProp>
      <boolProp name="TestPlan.tearDown_on_shutdown">true</boolProp>
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments" guiclass="ArgumentsPanel" testclass="Arguments" enabled="true">
        <collectionProp name="Arguments.arguments">
          <elementProp name="SEARCH_KEYWORD" elementType="Argument">
            <stringProp name="Argument.name">SEARCH_KEYWORD</stringProp>
            <stringProp name="Argument.value">IJ</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
        </collectionProp>
      </elementProp>
    </TestPlan>
