      <!-- ================================================================== -->
      <!--                                                                    -->
      <!--  TC03 - FULL KAPASITAS: Semua 15 Staff Online Bersamaan           -->
      <!--                                                                    -->
      <!--  Konteks nyata:                                                    -->
      <!--  Kondisi ekstrem: semua 15 admin & kasir login sekaligus.         -->
      <!--  Mungkin terjadi saat ada briefing/rapat sambil sistem jalan,     -->
      <!--  atau akhir bulan saat admin rekap + kasir tetap melayani.        -->
      <!--                                                                    -->
      <!--  User    : 15 (MAKSIMUM - semua staff online)                     -->
      <!--  Ramp-Up : 180 detik (login tersebar dalam 3 menit)               -->
      <!--  Loop    : 3x                                                      -->
      <!--  Think   : 5-15 detik (bervariasi, ada yang baca laporan          -->
      <!--            ada yang input transaksi cepat)                        -->
      <!--  Target  : Semua response &lt; 2000ms, Error = 0%               -->
      <!-- ================================================================== -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup"
                   testname="TC03 - FULL KAPASITAS: Semua 15 Staff Online Bersamaan"
                   enabled="false">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController"
                     guiclass="LoopControlPanel" testclass="LoopController"
                     testname="Loop Controller" enabled="true">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <stringProp name="LoopController.loops">3</stringProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">15</stringProp>
        <stringProp name="ThreadGroup.ramp_time">180</stringProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <boolProp name="ThreadGroup.scheduler">false</boolProp>
      </ThreadGroup>
      <hashTree>

        <!-- Login -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="[TC03-Full] 1. Buka Halaman Login" enabled="true">
          <stringProp name="HTTPSampler.path">/login</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <intProp name="HTTPSampler.connect_timeout">5000</intProp>
          <intProp name="HTTPSampler.response_timeout">10000</intProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments"
                       guiclass="HTTPArgumentsPanel" testclass="Arguments" enabled="true">
            <collectionProp name="Arguments.arguments"/>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree>
          <HtmlExtractor guiclass="HtmlExtractorGui" testclass="HtmlExtractor"
