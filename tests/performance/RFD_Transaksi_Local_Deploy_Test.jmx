<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="RFD Laundry — Transaksi Performance Test (TC-TRX-01 &amp; TC-TRX-02)" enabled="true">
      <stringProp name="TestPlan.comments">
====================================================================
FITUR      : MENGELOLA DATA TRANSAKSI
TESTER     : FAI
TEST CASE  : TC-TRX-01 (LOCAL)  — 200 user, ramp-up 30 detik
             TC-TRX-02 (DEPLOY) — 10 user,  ramp-up 60 detik

ENDPOINT YANG DIUJI:
  - GET  /login          → Ambil halaman login + CSRF token
  - POST /login          → Proses autentikasi
  - GET  /transaksi      → Tampil daftar transaksi (SELECT + JOIN)
  - GET  /transaksi?search → Pencarian transaksi (WHERE LIKE)

EXPECTED RESULT:
  - Response time average &lt; 5.000ms (5 detik)
  - Error rate = 0%

DEPLOY URL : https://laundry.aksaralearning.com
DEPLOY AUTH: admin / admin123  |  kasir / kasir123
====================================================================
      </stringProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <boolProp name="TestPlan.serialize_threadgroups">false</boolProp>
      <boolProp name="TestPlan.tearDown_on_shutdown">true</boolProp>
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments" guiclass="ArgumentsPanel" testclass="Arguments" testname="User Defined Variables (LOCAL Default)" enabled="true">
        <collectionProp name="Arguments.arguments">
          <elementProp name="BASE_URL" elementType="Argument">
            <stringProp name="Argument.name">BASE_URL</stringProp>
            <stringProp name="Argument.value">localhost</stringProp>
            <stringProp name="Argument.desc">LOCAL: localhost | DEPLOY: laundry.aksaralearning.com</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="BASE_PORT" elementType="Argument">
            <stringProp name="Argument.name">BASE_PORT</stringProp>
            <stringProp name="Argument.value">8000</stringProp>
            <stringProp name="Argument.desc">LOCAL: 8000 | DEPLOY: 443</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="BASE_PROTOCOL" elementType="Argument">
            <stringProp name="Argument.name">BASE_PROTOCOL</stringProp>
            <stringProp name="Argument.value">http</stringProp>
            <stringProp name="Argument.desc">LOCAL: http | DEPLOY: https</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="LOGIN_USERNAME" elementType="Argument">
            <stringProp name="Argument.name">LOGIN_USERNAME</stringProp>
            <stringProp name="Argument.value">1</stringProp>
            <stringProp name="Argument.desc">LOCAL: 1 | DEPLOY: admin atau kasir</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="LOGIN_PASSWORD" elementType="Argument">
            <stringProp name="Argument.name">LOGIN_PASSWORD</stringProp>
            <stringProp name="Argument.value">12345678</stringProp>
            <stringProp name="Argument.desc">LOCAL: 12345678 | DEPLOY: admin123 atau kasir123</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="SEARCH_KEYWORD" elementType="Argument">
            <stringProp name="Argument.name">SEARCH_KEYWORD</stringProp>
            <stringProp name="Argument.value">IJ</stringProp>
            <stringProp name="Argument.desc">Kata kunci pencarian transaksi</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
        </collectionProp>
      </elementProp>
    </TestPlan>
    <hashTree>
